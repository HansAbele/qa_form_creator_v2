generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  ADMIN
  QA
}

enum QuestionType {
  TEXT
  RATING
  SELECT
  RADIO
}

// ─── Auth.js required models ─────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuarios y campañas ─────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      Role     @default(QA)
  active    Boolean  @default(true)
  image     String?
  emailVerified DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  campaigns             UserCampaign[]
  forms                 Form[]                @relation("FormCreator")
  responses             Response[]            @relation("Evaluator")
  dispositionsCreated   Disposition[]         @relation("DispositionCreator")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                  UserCampaign[]
  forms                  Form[]
  agents                 Agent[]
  teams                  Team[]
  dispositionCategories  DispositionCategory[]
  dispositions           Disposition[]
}

model UserCampaign {
  userId     String
  campaignId String
  assignedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([userId, campaignId])
}

// ─── Equipos ─────────────────────────────────────────

model Team {
  id         String   @id @default(cuid())
  name       String
  campaignId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agents   Agent[]

  @@unique([name, campaignId])
  @@index([campaignId])
}

// ─── Agentes (no inician sesión) ─────────────────────

model Agent {
  id         String   @id @default(cuid())
  name       String
  agentCode  String?
  campaignId String
  teamId     String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  responses Response[]

  @@unique([agentCode, campaignId])
  @@index([teamId])
}

// ─── Formularios ─────────────────────────────────────

model Form {
  id          String   @id @default(cuid())
  title       String
  description String?
  campaignId  String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign  Campaign   @relation(fields: [campaignId], references: [id])
  createdBy User       @relation("FormCreator", fields: [createdById], references: [id])
  questions Question[]
  responses Response[]
}

model Question {
  id       String       @id @default(cuid())
  formId   String
  type     QuestionType
  label    String
  options  Json?
  required Boolean      @default(false)
  order    Int          @default(0)

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([formId, order])
}

// ─── Disposiciones ───────────────────────────────────

model DispositionCategory {
  id         String   @id @default(cuid())
  name       String
  campaignId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  dispositions Disposition[]

  @@unique([name, campaignId])
  @@index([campaignId])
}

model Disposition {
  id          String   @id @default(cuid())
  name        String
  code        String?
  categoryId  String?
  campaignId  String
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())

  category  DispositionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  campaign  Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("DispositionCreator", fields: [createdById], references: [id])
  responses Response[]

  @@unique([name, campaignId])
  @@index([campaignId, active])
  @@index([categoryId])
}

// ─── Evaluaciones ────────────────────────────────────

model Response {
  id            String   @id @default(cuid())
  formId        String
  agentId       String
  evaluatorId   String
  dispositionId String?
  score         Decimal  @db.Decimal(5, 2)
  createdAt     DateTime @default(now())

  form        Form         @relation(fields: [formId], references: [id])
  agent       Agent        @relation(fields: [agentId], references: [id])
  evaluator   User         @relation("Evaluator", fields: [evaluatorId], references: [id])
  disposition Disposition? @relation(fields: [dispositionId], references: [id])
  answers     Answer[]

  @@index([formId, createdAt])
  @@index([agentId])
  @@index([evaluatorId])
  @@index([dispositionId])
  @@index([createdAt])
}

model Answer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  value      String

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([responseId])
  @@index([questionId])
}

// ─── Configuración global ──────────────────────────────

/// Clave/valor JSON para settings globales del sistema (umbrales, targets, etc.)
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}
